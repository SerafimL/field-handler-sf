{
  "name": "field-handler-sf",
  "displayName": "Field Handler SF",
  "description": "Handle salesforce fields without having to edit xml ",
  "version": "0.0.1",
  "type": "module",
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "field-handler-sf.extractCurrentFile",
        "title": "Extract Current File"
      },
      {
        "command": "field-handler-sf.createField",
        "title": "Create Field With Current File"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "field-handler-sf.extractCurrentFile",
          "when": "editorLangId == xml"
        },
        {
          "command": "field-handler-sf.createField",
          "when": "editorLangId == json"
        }
      ]
    }
  },
  "scripts": {
    "lint": "eslint .",
    "pretest": "npm run lint",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3"
  },
  "dependencies": {
    "xml-js": "^1.6.11"
  }
}
